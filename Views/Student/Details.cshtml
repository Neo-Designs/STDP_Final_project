@model MentorMatch.Models.Proposal
@{
    ViewData["Title"] = "Proposal Details";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="glass-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <a asp-action="Dashboard" class="text-white-50 text-decoration-none small mb-2 d-inline-block">
                        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                    </a>
                    <h2 class="fw-bold mb-0">Project <span class="text-info">Details</span></h2>
                </div>
                <div class="text-end">
                    <span class="status-badge status-@(Model.Status.ToString().ToLower()) px-4 py-2 fs-6">
                        @Model.Status
                    </span>
                    <div class="text-muted small mt-2">@Model.Module.Code - @Model.Module.Name</div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-8">
                    <div class="mb-5">
                        <h4 class="fw-bold text-white border-bottom border-white border-opacity-10 pb-2 mb-3">@Model.Title</h4>
                        <div class="d-flex gap-2 mb-4">
                            @foreach (var pt in Model.ProposalTags)
                            {
                                <span class="badge bg-info text-dark opacity-75">#@pt.Tag.Name</span>
                            }
                        </div>
                        
                        <h6 class="text-info small fw-bold text-uppercase mb-2">Abstract</h6>
                        <p class="text-white-50 leading-relaxed mb-4">@Model.Abstract</p>

                        <div class="row g-4 mb-4">
                            <div class="col-sm-6">
                                <h6 class="text-info small fw-bold text-uppercase mb-2">Technical Stack</h6>
                                <div class="bg-white bg-opacity-5 p-3 rounded border border-white border-opacity-10">
                                    @Model.TechnicalStack
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <h6 class="text-info small fw-bold text-uppercase mb-2">Research Area</h6>
                                <div class="bg-white bg-opacity-5 p-3 rounded border border-white border-opacity-10">
                                    @Model.ResearchArea
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.FilePath))
                        {
                            <div class="mt-4">
                                <a href="@Model.FilePath" target="_blank" class="glass-button glass-button-blue px-4 py-2">
                                    <i class="bi bi-file-earmark-pdf me-2"></i> View Uploaded PDF
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    @if (Model.Status == ProposalStatus.Matched && Model.Match != null)
                    {
                        <div class="glass-card border-success border-opacity-25" style="background: rgba(40, 167, 69, 0.05);">
                            <h5 class="fw-bold text-success mb-3"><i class="bi bi-person-check-fill me-2"></i>Supervisor Info</h5>
                            <div class="mb-3">
                                <label class="text-muted small d-block">Name</label>
                                <div class="fw-bold">@Model.Match.Supervisor.FirstName @Model.Match.Supervisor.LastName</div>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted small d-block">Contact Email</label>
                                <a href="mailto:@Model.Match.Supervisor.Email" class="text-info text-decoration-none">@Model.Match.Supervisor.Email</a>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Match.Supervisor.ContactDetails))
                            {
                                <div class="mb-3">
                                    <label class="text-muted small d-block">Other Contact</label>
                                    <div>@Model.Match.Supervisor.ContactDetails</div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(Model.Match.Message))
                            {
                                <div class="mt-4 p-3 bg-white bg-opacity-5 rounded border-start border-4 border-success">
                                    <label class="text-success small fw-bold d-block mb-1">Supervisor's Note</label>
                                    <div class="fst-italic small">"@Model.Match.Message"</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="glass-card bg-opacity-10">
                            <h5 class="fw-bold mb-3">Proposal Info</h5>
                            <div class="mb-3">
                                <label class="text-muted small d-block">Submission Type</label>
                                <div>@Model.ProjectType Project</div>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted small d-block">Submitted On</label>
                                <div>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                            </div>
                            <div class="mt-4">
                                <div class="alert alert-info bg-info bg-opacity-10 border-info border-opacity-25 text-info small">
                                    @if(Model.Status == ProposalStatus.Pending) {
                                        <span>Your proposal is currently waiting to be reviewed by a supervisor.</span>
                                    } else if(Model.Status == ProposalStatus.UnderReview) {
                                        <span>Your proposal is currently being reviewed. You will be notified of any updates.</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
