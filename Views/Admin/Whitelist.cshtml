@model IEnumerable<MentorMatch.Models.PredefinedEmail>
@{
    ViewData["Title"] = "Email Whitelist";
}

<div class="row">
    <div class="col-lg-4 mb-4">
        <div class="glass-card mb-4">
            <h4 class="fw-bold mb-4">Direct <span class="text-primary">Creation</span></h4>
            <p class="x-small text-muted mb-3">Create an account immediately with a password.</p>
            <form asp-action="CreateAccount" method="post">
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label small text-muted">First Name</label>
                        <input type="text" name="firstName" class="form-control" placeholder="Jane" required />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label small text-muted">Last Name</label>
                        <input type="text" name="lastName" class="form-control" placeholder="Doe" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="admin@mentormatch.com" required />
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Initial Password</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>
                <div class="mb-4">
                    <label class="form-label small text-muted">Role</label>
                    <select name="role" class="form-control">
                        <option value="Supervisor">Supervisor</option>
                        <option value="Admin">Admin</option>
                        <option value="Student">Student</option>
                    </select>
                </div>
                <button type="submit" class="glass-button w-100">Create Account</button>
            </form>
        </div>

        <div class="glass-card">
            <h4 class="fw-bold mb-4">Issue <span class="text-secondary">Invite</span></h4>
            <p class="x-small text-muted mb-3">Whitelist an email for future student/faculty registration.</p>
            <form asp-action="IssueEmail" method="post">
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label small text-muted">First Name</label>
                        <input type="text" name="firstName" class="form-control" placeholder="John" required />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label small text-muted">Last Name</label>
                        <input type="text" name="lastName" class="form-control" placeholder="Smith" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">Email Address</label>
                    <input type="email" name="email" class="form-control" placeholder="faculty@university.edu" required />
                </div>
                <div class="mb-4">
                    <label class="form-label small text-muted">Role</label>
                    <select name="role" class="form-control">
                        <option value="Supervisor">Supervisor</option>
                        <option value="Admin">Admin</option>
                        <option value="Student">Student</option>
                    </select>
                </div>
                <button type="submit" class="glass-button glass-button-blue w-100">Add to Whitelist</button>
            </form>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="glass-card">
            <h4 class="fw-bold mb-4">Current <span class="text-info">Whitelisted Emails</span></h4>
            <div class="table-responsive">
                <table class="table table-borderless text-white small">
                    <thead>
                        <tr class="border-bottom border-white border-opacity-10">
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Issued On</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="border-bottom border-white border-opacity-5">
                                <td class="py-3">@item.Email</td>
                                <td class="py-3">
                                    <span class="badge @(item.RoleRequested == UserType.Admin ? "bg-danger" : "bg-primary") bg-opacity-25">
                                        @item.RoleRequested
                                    </span>
                                </td>
                                <td class="py-3">
                                    @if (item.IsUsed)
                                    {
                                        <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> Signed Up</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning"><i class="bi bi-clock me-1"></i> Pending</span>
                                    }
                                </td>
                                <td class="py-3 text-black-dark">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
