@model IEnumerable<MentorMatch.Models.Proposal>
@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="mb-5">
    <h2 class="fw-bold fs-1">My <span class="text-primary">Proposals</span></h2>
    <p class="text-muted">Manage your active project submissions and tracking match status.</p>
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-file-earmark-plus display-1 text-muted opacity-25"></i>
            <h4 class="text-muted mt-3">No proposals yet</h4>
            <a asp-action="Submit" class="glass-button mt-3">Get Started</a>
        </div>
    }
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="glass-card h-100 d-flex flex-column hover-scale">
                <div class="d-flex justify-content-between mb-3 align-items-center">
                    <span class="status-badge status-@(item.Status.ToString().ToLower()) px-3 py-1">
                        @item.Status
                    </span>
                    <span class="small fw-bold opacity-50">@item.Module.Code</span>
                </div>
                
                <h5 class="fw-bold mb-2">@item.Title</h5>
                <p class="text-muted small flex-grow-1">@(item.Abstract.Length > 120 ? item.Abstract.Substring(0, 120) + "..." : item.Abstract)</p>
                
                <div class="my-3 d-flex flex-wrap gap-1">
                    @foreach (var pt in item.ProposalTags)
                    {
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2">#@pt.Tag.Name</span>
                    }
                </div>

                @if (item.Status == ProposalStatus.Matched && item.Match != null)
                {
                    <div class="mt-2 p-3 bg-success bg-opacity-10 rounded-4 border border-success border-opacity-25">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-person-check-fill text-success fs-5 me-2"></i>
                            <h6 class="text-success small fw-bold mb-0">Matched Supervisor</h6>
                        </div>
                        <p class="mb-0 small fw-bold text-main">@item.Match.Supervisor.FirstName @item.Match.Supervisor.LastName</p>
                        @if (!string.IsNullOrEmpty(item.Match.Supervisor.ContactDetails))
                        {
                            <div class="x-small text-muted mt-1">
                                <i class="bi bi-geo-alt-fill me-1"></i> @item.Match.Supervisor.ContactDetails
                            </div>
                        }
                        <a href="mailto:@item.Match.Supervisor.Email" class="text-secondary x-small d-block opacity-75 mt-1 fw-bold">@item.Match.Supervisor.Email</a>
                    </div>
                }

                <div class="mt-4 pt-3 border-top border-white border-opacity-10 d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id" class="glass-button glass-button-blue py-2 px-3 small flex-grow-1 text-center">View</a>
                    @if (item.Status == ProposalStatus.Pending)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm py-2 px-3 border-opacity-25 opacity-75">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this proposal?');" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm py-2 px-3 border-opacity-25 opacity-75">Delete</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="fixed-bottom p-4 text-center" style="z-index: 999;">
    <a asp-action="Submit" class="glass-button px-5 py-3 shadow-lg rounded-pill fw-bold text-uppercase animate-float" style="letter-spacing: 1px;">
        <i class="bi bi-plus-lg me-2"></i> Submit New Proposal
    </a>
</div>

<div style="height: 100px;"></div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
