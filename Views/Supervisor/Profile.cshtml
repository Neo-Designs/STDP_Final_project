@model MentorMatch.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    var allTags = (List<MentorMatch.Models.Tag>)ViewBag.AllTags;
    var myTagIds = (List<int>)ViewBag.MyTags;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="glass-card">
            <h2 class="fw-bold mb-4">Supervisor <span class="text-success">Profile</span></h2>
            
            <form asp-action="Profile" method="post">
                @Html.AntiForgeryToken()
                
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <label class="form-label small text-muted">First Name</label>
                        <input asp-for="FirstName" class="form-control glass-nav border-white border-opacity-25 text-white" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Last Name</label>
                        <input asp-for="LastName" class="form-control glass-nav border-white border-opacity-25 text-white" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted">Email Address (Faculty - Fixed)</label>
                    <input class="form-control glass-nav border-white border-opacity-10 text-white-50" value="@Model.Email" readonly style="cursor: not-allowed;" />
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted">Contact Details / Office Info</label>
                    <textarea asp-for="ContactDetails" class="form-control glass-nav border-white border-opacity-25 text-white" rows="2" placeholder="e.g. Office 302, ext 1234"></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted">Update Password (Optional)</label>
                    <input type="password" name="newPassword" class="form-control glass-nav border-white border-opacity-25 text-white" placeholder="Leave empty to keep current password" />
                </div>

                <div class="mb-4">
                    <label class="form-label small text-muted d-block mb-3">Expertise Tags</label>
                    <div class="row g-2">
                        @foreach (var tag in allTags)
                        {
                            <div class="col-auto">
                                <div class="form-check p-0">
                                    <input type="checkbox" class="btn-check" id="tag-@tag.Id" name="selectedTags" value="@tag.Id" @(myTagIds.Contains(tag.Id) ? "checked" : "")>
                                    <label class="oval-filter m-0 py-2 px-4 shadow-sm" for="tag-@tag.Id" style="cursor: pointer;">
                                        @tag.Name
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-5">
                    <a asp-action="Dashboard" class="text-white-50 text-decoration-none small">Back to Dashboard</a>
                    <button type="submit" class="glass-button glass-button-green px-5 py-3 fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
