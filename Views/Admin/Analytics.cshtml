@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="row">
    <!-- Stat Cards -->
    <div class="col-md-4 mb-4">
        <div class="glass-card text-center">
            <h1 class="fw-bold text-primary display-4">@ViewBag.Matches</h1>
            <p class="text-muted mb-0">Total Matches</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="glass-card text-center">
            <h1 class="fw-bold text-secondary display-4">@ViewBag.Students</h1>
            <p class="text-muted mb-0">Registered Students</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="glass-card text-center">
            <h1 class="fw-bold opacity-75 display-4">@ViewBag.Supervisors</h1>
            <p class="text-muted mb-0">Supervisors</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="glass-card">
            <h4 class="fw-bold mb-4">Proposal <span class="text-info">Status Distribution</span></h4>
            <div style="height: 300px;">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4 mb-4">
        <div class="glass-card">
            <h4 class="fw-bold mb-4">System <span class="text-info">Overview</span></h4>
            <ul class="list-unstyled">
                <li class="mb-3 d-flex justify-content-between border-bottom border-white border-opacity-10 pb-2">
                    <span class="text-muted">Database Server</span>
                    <span class="fw-bold">MS SQL Server</span>
                </li>
                <li class="mb-3 d-flex justify-content-between border-bottom border-white border-opacity-10 pb-2">
                    <span class="text-muted">Connectivity</span>
                    <span class="fw-bold">EF Core 8</span>
                </li>
                <li class="mb-3 d-flex justify-content-between border-bottom border-white border-opacity-10 pb-2">
                    <span class="text-muted">Storage Mode</span>
                    <span class="fw-bold">Local (wwwroot)</span>
                </li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            fetch('/Admin/GetChartData')
                .then(r => r.json())
                .then(data => {
                    const ctx = document.getElementById('statusChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.map(d => d.status),
                            datasets: [{
                                label: 'Number of Proposals',
                                data: data.map(d => d.count),
                                backgroundColor: [
                                    'rgba(255, 209, 102, 0.4)',  // Pending
                                    'rgba(58, 134, 255, 0.4)',   // Review
                                    'rgba(6, 214, 160, 0.4)'    // Matched
                                ],
                                borderColor: [
                                    '#ffd166', '#3a86ff', '#06d6a0'
                                ],
                                borderWidth: 2,
                                borderRadius: 10,
                                hoverBackgroundColor: [
                                    'rgba(255, 209, 102, 0.8)',
                                    'rgba(58, 134, 255, 0.8)',
                                    'rgba(6, 214, 160, 0.8)'
                                ]
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: getComputedStyle(document.documentElement).getPropertyValue('--bg-color'),
                                    titleColor: getComputedStyle(document.documentElement).getPropertyValue('--primary-main'),
                                    bodyColor: getComputedStyle(document.documentElement).getPropertyValue('--text-main'),
                                    borderColor: getComputedStyle(document.documentElement).getPropertyValue('--glass-border'),
                                    borderWidth: 1,
                                    padding: 12,
                                    cornerRadius: 10,
                                    displayColors: false
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: { color: getComputedStyle(document.documentElement).getPropertyValue('--glass-border') },
                                    ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-muted'), font: { family: 'Inter' } }
                                },
                                x: {
                                    grid: { display: false },
                                    ticks: { color: getComputedStyle(document.documentElement).getPropertyValue('--text-main'), font: { weight: 'bold', family: 'Inter' } }
                                }
                            }
                        }
                    });
                });
        });
    </script>
}
