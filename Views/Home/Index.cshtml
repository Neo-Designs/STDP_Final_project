@{
    ViewData["Title"] = "Welcome";
}

<div class="row min-vh-75 align-items-center justify-content-center text-center py-5">
    <div class="col-lg-8 mb-5">
        <div class="animate-float mb-4">
            <span class="badge rounded-pill bg-success bg-opacity-25 text-success border border-success border-opacity-50 px-3 py-2 mb-3">
                <i class="bi bi-stars me-1"></i> New: Intelligent Allocation Algorithm
            </span>
        </div>
        <h1 class="display-2 fw-bold mb-4">
            <span class="text-success">Match</span> Your Future <br /> 
            <span class="text-info">Project</span> with Confidence.
        </h1>
        <p class="lead text-white-50 mb-5 mx-auto" style="max-width: 700px;">
            The Blind-Match Project Approval System (PAS) ensures fair, expertise-driven pairing between students and supervisors through anonymous review and smart expertise mapping.
        </p>
        <div class="d-flex gap-3 justify-content-center">
            <a href="/Identity/Account/Register" class="glass-button glass-button-green px-5 py-3 hover-scale fw-bold">Get Started Now</a>
            <a href="/Identity/Account/Login" class="glass-button px-5 py-3 hover-scale fw-bold">Sign In</a>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
