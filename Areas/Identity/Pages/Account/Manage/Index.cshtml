@page
@model IndexModel
@{
    ViewData["Title"] = "Profile Settings";
    ViewData["ActivePage"] = "Index";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="glass-card">
            <h2 class="fw-bold mb-4">Account <span class="text-primary">Settings</span></h2>
            <partial name="_StatusMessage" for="StatusMessage" />

            <form id="profile-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="row g-4 mb-5">
                    <div class="col-md-6 border-end border-white border-opacity-10">
                        <h5 class="fw-bold mb-4 text-muted small text-uppercase">Public Information</h5>
                        
                        <div class="mb-3">
                            <label class="form-label small text-muted">Email (Username)</label>
                            <input asp-for="Username" class="form-control glass-nav border-white border-opacity-10 text-white-50" disabled />
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="Input.FirstName" class="form-label small text-muted"></label>
                                <input asp-for="Input.FirstName" class="form-control" />
                                <span asp-validation-for="Input.FirstName" class="text-danger x-small"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="Input.LastName" class="form-label small text-muted"></label>
                                <input asp-for="Input.LastName" class="form-control" />
                                <span asp-validation-for="Input.LastName" class="text-danger x-small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label small text-muted"></label>
                            <input asp-for="Input.PhoneNumber" class="form-control" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger x-small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        @if (Model.IsSupervisor)
                        {
                            <h5 class="fw-bold mb-4 text-success small text-uppercase">Supervisor Details</h5>
                            
                            <div class="mb-4">
                                <label asp-for="Input.ContactDetails" class="form-label small text-muted"></label>
                                <textarea asp-for="Input.ContactDetails" class="form-control" rows="3" placeholder="Office location, hours, etc."></textarea>
                                <span asp-validation-for="Input.ContactDetails" class="text-danger x-small"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small text-muted d-block mb-3">Expertise Tags</label>
                                <div class="row g-2">
                                    @foreach (var tag in Model.AllTags)
                                    {
                                        <div class="col-auto">
                                            <div class="form-check p-0">
                                                <input type="checkbox" class="btn-check" id="tag-@tag.Id" name="selectedTags" value="@tag.Id" @(Model.Input.SelectedTags.Contains(tag.Id) ? "checked" : "")>
                                                <label class="oval-filter m-0 py-2 px-3 small border-white border-opacity-25" for="tag-@tag.Id" style="cursor: pointer;">
                                                    @tag.Name
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="h-100 d-flex align-items-center justify-content-center text-center p-4">
                                <div>
                                    <i class="bi bi-person-gear display-1 text-muted opacity-25"></i>
                                    <p class="text-muted small mt-3">Basic account management for @Model.Username</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="pt-4 border-top border-white border-opacity-10 d-flex justify-content-between align-items-center">
                    <button id="update-profile-button" type="submit" class="glass-button glass-button-green px-5 py-3 fw-bold">Save All Changes</button>
                    <a asp-action="Index" asp-controller="Home" class="text-white-50 text-decoration-none small">Back to Home</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
