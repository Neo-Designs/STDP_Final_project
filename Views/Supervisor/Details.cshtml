@model MentorMatch.Models.Proposal
@{
    ViewData["Title"] = "Review Proposal";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="glass-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <form asp-action="RevertToPending" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-link text-white-50 text-decoration-none small mb-2 p-0">
                            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                        </button>
                    </form>
                    <h2 class="fw-bold mb-0">Review <span class="text-success">Proposal</span></h2>
                </div>
                <div class="text-end">
                    <span class="status-badge status-@(Model.Status.ToString().ToLower()) px-4 py-2 fs-6">
                        @Model.Status
                    </span>
                    <div class="text-white-50 small mt-2">
                        @if (Model.Status == ProposalStatus.Matched)
                        {
                            <div class="text-info fw-bold mb-1">
                                <i class="bi bi-person-check-fill me-1"></i> Matched with: @Model.Student.FirstName @Model.Student.LastName
                            </div>
                            <div class="x-small">@Model.Student.Email | @Model.Student.StudentNumber</div>
                        }
                        else
                        {
                            <span class="text-white-50"><i class="bi bi-shield-lock me-1"></i> Blind Match: Identity Hidden</span>
                        }
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-8">
                    <div class="mb-5">
                        <h4 class="fw-bold text-white border-bottom border-white border-opacity-10 pb-2 mb-3">@Model.Title</h4>
                        <div class="d-flex gap-2 mb-4">
                            @foreach (var pt in Model.ProposalTags)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">#@pt.Tag.Name</span>
                            }
                        </div>
                        
                        <h6 class="text-success small fw-bold text-uppercase mb-2">Abstract</h6>
                        <p class="text-white-50 leading-relaxed mb-4">@Model.Abstract</p>

                        <div class="row g-4 mb-4">
                            <div class="col-sm-6">
                                <h6 class="text-success small fw-bold text-uppercase mb-2">Technical Stack</h6>
                                <div class="bg-white bg-opacity-5 p-3 rounded border border-white border-opacity-10 review-field-box fw-bold">
                                    @Model.TechnicalStack
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <h6 class="text-success small fw-bold text-uppercase mb-2">Research Area</h6>
                                <div class="bg-white bg-opacity-5 p-3 rounded border border-white border-opacity-10 review-field-box fw-bold">
                                    @Model.ResearchArea
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.FilePath))
                        {
                            <div class="mt-4">
                                <a href="@Model.FilePath" target="_blank" class="glass-button glass-button-blue px-4 py-2">
                                    <i class="bi bi-file-earmark-pdf me-2"></i> Download / View Proposal PDF
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-card" style="background: rgba(255, 255, 255, 0.03);">
                        <h5 class="fw-bold mb-4">Match Action</h5>
                        
                        <form asp-action="Match" method="post">
                            <input type="hidden" name="proposalId" value="@Model.Id" />
                            
                            <div class="mb-4 text-center">
                                <label class="form-label small text-muted text-start d-block mb-2">Message to Student (Optional)</label>
                                <textarea name="message" class="form-control glass-nav border-white border-opacity-25 text-white" rows="6" placeholder="Leave a note or contact instructions..."></textarea>
                            </div>

                            <div class="text-center">
                                <button type="submit" class="glass-button glass-button-green w-100 py-3 fw-bold">
                                    MATCH WITH PROJECT
                                </button>
                                <p class="text-muted small mt-3">Matching will notify the student and share your contact details.</p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
